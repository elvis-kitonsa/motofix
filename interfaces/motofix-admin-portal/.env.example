# ─────────────────────────────────────────────────────────────────────────────
# motofix-admin-portal — environment variables
# Copy this file to .env.local for local development.
#
# NOTE: All VITE_ variables are baked into the JavaScript bundle at build time.
# To change them you must rebuild the app (npm run build).
# For Docker builds, pass these as --build-arg values (see Dockerfile).
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the admin/analytics backend (motofix-analytics-service).
VITE_API_BASE_URL=http://localhost:8005
VITE_API_ADMIN_URL=http://localhost:8005

# Other backend services the portal talks to.
VITE_API_AUTH_URL=http://localhost:8000
VITE_API_REQUESTS_URL=http://localhost:8001
VITE_API_MECHANICS_URL=http://localhost:8002
VITE_API_NOTIFICATIONS_URL=http://localhost:8004

# ── Google Maps (enable Maps JavaScript API) ────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
