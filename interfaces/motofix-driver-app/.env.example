# ─────────────────────────────────────────────────────────────────────────────
# motofix-driver-app — environment variables
# Copy this file to .env.local for local development.
#
# NOTE: All VITE_ variables are baked into the JavaScript bundle at build time.
# To change them you must rebuild the app (npm run build).
# For Docker builds, pass these as --build-arg values (see Dockerfile).
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend service URLs (change to your deployed URLs in production) ────────
VITE_API_AUTH_URL=http://localhost:8000
VITE_API_REQUESTS_URL=http://localhost:8001
VITE_API_PAYMENTS_URL=http://localhost:8001
VITE_API_DIAGNOSIS_URL=http://localhost:8007
VITE_API_MATCHING_URL=http://localhost:8003
VITE_API_INSURANCE_URL=http://localhost:8006

# Realtime job updates (dispatch service websocket).
VITE_WS_URL=ws://localhost:8001/ws/jobs

# Link out to the service-provider app.
VITE_PROVIDER_URL=http://localhost:8084

# ── Google Maps (enable Maps JavaScript API) ────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GOOGLE_MAPS_MAP_ID=your_map_id_here

# ── Firebase web config (push notifications) ────────────────────────────────
# These are public-by-design client values; still restrict the key by HTTP
# referrer in Google Cloud Console. Get them from the Firebase console.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key
