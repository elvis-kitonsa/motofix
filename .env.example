# ─────────────────────────────────────────────────────────────────────────────
# MOTOFIX — root environment variables
# Copy this file to .env and fill in your values. The real .env is git-ignored.
#
# docker-compose reads these to build the frontends (VITE_* baked in at build
# time) and to configure the notifications service.
#
# SECURITY:
#   - FIREBASE_SERVICE_ACCOUNT_JSON and AT_API_KEY are TRUE SECRETS — never commit.
#   - The VITE_FIREBASE_* and VITE_GOOGLE_MAPS_API_KEY values are public-by-design
#     client keys (they ship in the browser bundle), but still restrict them by
#     HTTP referrer / allowed APIs in the Google Cloud & Firebase consoles.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps (baked into the frontend apps at build time) ─────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Firebase / FCM (server-side, notifications service) ──────────────────────
FCM_PROJECT_ID=your_firebase_project_id
# Paste the full service-account JSON on one line. REAL SECRET — keep out of git.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Firebase web config (baked into the frontend apps at build time) ─────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# ── Africa's Talking (SMS / WhatsApp, notifications service) ──────────────────
AT_USERNAME=sandbox
AT_API_KEY=

# ── MTN MoMo (payments, dispatch service) ────────────────────────────────────
MOMO_ENVIRONMENT=sandbox
MOMO_CURRENCY=EUR
MOMO_COLLECTIONS_USER_ID=
MOMO_COLLECTIONS_API_KEY=
MOMO_COLLECTIONS_PRIMARY_KEY=
MOMO_DISBURSEMENTS_USER_ID=
MOMO_DISBURSEMENTS_API_KEY=
MOMO_DISBURSEMENTS_PRIMARY_KEY=

# ── Airtel Money (payments, dispatch service) ────────────────────────────────
AIRTEL_ENV=sandbox
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_MERCHANT_PIN=
