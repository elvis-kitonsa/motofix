# ─────────────────────────────────────────────────────────────────────────────
# motofix-dispatch-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_dispatch

# ── JWT — must match the SECRET_KEY in motofix-auth-service ─────────────────
SECRET_KEY=change_me_in_production
ALGORITHM=HS256

# ── Inter-service URLs ───────────────────────────────────────────────────────
# URL of the analytics service (handles SMS, push and WhatsApp notifications).
NOTIFICATIONS_URL=http://localhost:8005

# URL of the matching service (called when a new breakdown request is created).
MATCHING_SERVICE_URL=http://localhost:8006

# ── Media storage (optional) ─────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user_uuid
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_ENVIRONMENT=sandbox

# ── Airtel Money ─────────────────────────────────────────────────────────────
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_ENVIRONMENT=sandbox
