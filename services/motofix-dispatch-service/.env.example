# ─────────────────────────────────────────────────────────────────────────────
# motofix-dispatch-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_dispatch

# ── JWT — must match the SECRET_KEY in motofix-auth-service ─────────────────
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
# Separate key used to validate driver app tokens (falls back to SECRET_KEY).
DRIVER_SECRET_KEY=change_me_in_production

# ── Inter-service URLs ───────────────────────────────────────────────────────
# Notifications sub-service (SMS / WhatsApp / push). Default port 8004.
NOTIFICATIONS_URL=http://localhost:8004
# Matching service, called when a new breakdown request is created. Default port 8003.
MATCHING_SERVICE_URL=http://localhost:8003

# ── Media storage ────────────────────────────────────────────────────────────
# STORAGE_PROVIDER: cloudinary | s3 | local (falls back to local disk).
STORAGE_PROVIDER=cloudinary
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# Local-disk fallback (used when STORAGE_PROVIDER=local or creds are missing).
MEDIA_DIR=./media
DISPATCH_PUBLIC_URL=http://localhost:8001
# S3 alternative (only if STORAGE_PROVIDER=s3).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# ── Geocoding ────────────────────────────────────────────────────────────────
# Optional Google Geocoding key for reverse-geocoding request locations.
GOOGLE_GEOCODING_API_KEY=your_google_geocoding_api_key

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
MOMO_ENVIRONMENT=sandbox
# Sandbox accepts EUR; production uses UGX (auto-selected if unset).
MOMO_CURRENCY=EUR
MOMO_CALLBACK_URL=https://your-host/payments/callback
# Collections (charging drivers)
MOMO_COLLECTIONS_USER_ID=your_momo_collections_user_id
MOMO_COLLECTIONS_API_KEY=your_momo_collections_api_key
MOMO_COLLECTIONS_PRIMARY_KEY=your_momo_collections_primary_key
# Disbursements (paying out)
MOMO_DISBURSEMENTS_USER_ID=your_momo_disbursements_user_id
MOMO_DISBURSEMENTS_API_KEY=your_momo_disbursements_api_key
MOMO_DISBURSEMENTS_PRIMARY_KEY=your_momo_disbursements_primary_key

# ── Airtel Money ─────────────────────────────────────────────────────────────
AIRTEL_ENV=staging
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_MERCHANT_PIN=your_airtel_merchant_pin

# ── Advanced / operational ───────────────────────────────────────────────────
# SERVICE_VARIANT: optional tag to run a specialised dispatch variant.
# SERVICE_VARIANT=
# Set to "1" to allow destructive DB migrations on startup (dangerous).
ALLOW_DESTRUCTIVE_MIGRATIONS=0
