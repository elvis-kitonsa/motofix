# ─────────────────────────────────────────────────────────────────────────────
# motofix-payments-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for this service's own database.
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_payments

# ── JWT validation keys ──────────────────────────────────────────────────────
# IMPORTANT: SECRET_KEY must match the key used by motofix-auth-service.
# DRIVER_SECRET_KEY must match the key used by motofix-auth-service for driver tokens.
# In many deployments both keys are the same value.
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
DRIVER_SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Platform commission deducted from each job (in lowest currency unit, e.g. UGX).
PLATFORM_COMMISSION=10000

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
# Get credentials from https://momodeveloper.mtn.com
# Use sandbox credentials for local dev — no real money moves.
MOMO_COLLECTIONS_USER_ID=your_collections_user_id_here
MOMO_COLLECTIONS_API_KEY=your_collections_api_key_here
MOMO_COLLECTIONS_PRIMARY_KEY=your_collections_primary_key_here

MOMO_DISBURSEMENTS_USER_ID=your_disbursements_user_id_here
MOMO_DISBURSEMENTS_API_KEY=your_disbursements_api_key_here
MOMO_DISBURSEMENTS_PRIMARY_KEY=your_disbursements_primary_key_here

# Set to "sandbox" for local dev, "mtncongo" / "mtnuganda" etc. for production.
MOMO_ENV=sandbox
