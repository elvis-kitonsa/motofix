# ─────────────────────────────────────────────────────────────────────────────
# motofix-auth-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for this service's own database.
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_auth

# ── JWT signing key ──────────────────────────────────────────────────────────
# IMPORTANT: This key MUST match the SECRET_KEY in every other service that
# validates tokens issued by the auth service (motofix-service-requests,
# motofix-mechanics-service, motofix-payments-service, motofix-admin-dashboard).
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# ── Token lifetimes ──────────────────────────────────────────────────────────
# Driver/provider tokens (hours, default 24) and admin tokens (hours, default 8).
ACCESS_TOKEN_EXPIRE_HOURS=24
ADMIN_TOKEN_EXPIRE_HOURS=8
# Some flows set the cookie max-age in seconds instead (optional).
# ACCESS_TOKEN_EXPIRE_SECONDS=86400

# Deployment environment: development | production (controls secure-cookie flags).
ENV=development

# ── Africa's Talking (OTP SMS) ───────────────────────────────────────────────
# If unset, the OTP is printed to the server console instead of being sent.
AT_USERNAME=your_africas_talking_username
AT_API_KEY=your_africas_talking_api_key

# ── Claude / Anthropic (AI document verification) ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Uploads & links ──────────────────────────────────────────────────────────
# Where uploaded provider-application documents are stored.
UPLOAD_DIR=./uploads
# Provider app base URL, used in application status emails/links.
PROVIDER_APP_URL=http://localhost:8088

# ── Seed script passwords (used by seed_admin.py) ───────────────────────────
# Passwords for the demo admin / mechanic / towing accounts created when seeding.
# Choose strong values; these are NOT committed.
SEED_ADMIN_PASSWORD=change_me
SEED_MECHANIC_PASSWORD=change_me

# ── Gmail SMTP (OTP + admin notifications) ──────────────────────────────────
# Enable 2-Step Verification on your Google account, then generate a 16-char
# App Password at: https://myaccount.google.com/apppasswords
# Use that App Password here — NOT your actual Gmail password.
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=MOTOFIX <your_gmail_address@gmail.com>
