# ─────────────────────────────────────────────────────────────────────────────
# motofix-mechanics-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for this service's own database.
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_mechanics

# ── JWT signing key ──────────────────────────────────────────────────────────
# IMPORTANT: This key MUST match the SECRET_KEY used in motofix-auth-service
# and any service that validates mechanic tokens (motofix-service-requests,
# motofix-payments-service). All services that share JWT validation must use
# the same key.
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Mechanic token lifetime in hours (default: 72).
TOKEN_EXPIRE_HOURS=72

# ── Dispatch service ─────────────────────────────────────────────────────────
# Used to fetch a mechanic's current/handled jobs and history from dispatch.
DISPATCH_SERVICE_URL=http://localhost:8001
