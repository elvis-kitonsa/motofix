# ─────────────────────────────────────────────────────────────────────────────
# motofix-analytics-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for this service's own database.
# Requests/payments database — must match motofix-dispatch-service DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_service_requests

# Auth database — must match motofix-auth-service DATABASE_URL
# Used to read mechanics, towing_providers, admins, users tables
AUTH_DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_auth

# ── JWT signing key ──────────────────────────────────────────────────────────
# IMPORTANT: This key MUST match the SECRET_KEY in motofix-auth-service if the
# admin dashboard validates driver/mechanic tokens. Use ADMIN_JWT_SECRET for
# tokens issued specifically to admin users (can be a separate key).
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
ADMIN_JWT_SECRET=change_me_in_production_admin_secret

ALGORITHM=HS256

# Port the service listens on.
PORT=8005

# Comma-separated list of allowed CORS origins (in addition to defaults).
# Example: CORS_ORIGINS=http://localhost:8082,https://admin.motofix.org
CORS_ORIGINS=http://localhost:8082

# Admin token lifetime in minutes.
ADMIN_TOKEN_EXPIRE_MINUTES=480

# Admin credentials (used for initial login before JWT is issued).
# Prefer ADMIN_PASSWORD_HASH (bcrypt) in production; it takes precedence over
# the plain ADMIN_PASSWORD when both are set.
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change_me_in_production
