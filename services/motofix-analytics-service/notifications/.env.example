# ─────────────────────────────────────────────────────────────────────────────
# motofix-notifications-service — environment variables
# Copy this file to .env and fill in your values.
#
# This service has NO database — it is stateless and can be scaled freely.
# It does NOT share a JWT secret with other services; it accepts calls only
# from internal services (no public auth required on its endpoints).
# ─────────────────────────────────────────────────────────────────────────────

# Port the service listens on.
PORT=8004

# ── Africa's Talking (SMS + WhatsApp) ───────────────────────────────────────
# Leave AT_USERNAME=sandbox for development (API calls accepted, no real SMS sent).
# Set to your production username and a live API key for production.
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here
