# ─────────────────────────────────────────────────────────────────────────────
# motofix-mechanic-matching — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for dispatch attempt history.
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_matching

# ── JWT validation ───────────────────────────────────────────────────────────
# IMPORTANT: Must match the SECRET_KEY used by motofix-auth-service and all
# other services that issue or validate JWT tokens on the platform.
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# ── Mechanic Verification Service ────────────────────────────────────────────
# URL of the motofix-mechanics-service instance.
# The matching service calls this to fetch the list of available verified mechanics.
MECHANICS_SERVICE_URL=http://localhost:8002
