# ─────────────────────────────────────────────────────────────────────────────
# motofix-diagnosis-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT validation ───────────────────────────────────────────────────────────
# Must match SECRET_KEY in motofix-auth-service so driver/mechanic tokens work.
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Port the service listens on (default: 8004).
PORT=8007

# ── Groq AI API ──────────────────────────────────────────────────────────────
# Used for fault text diagnosis (/diagnose) and AI chatbot (/chat).
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: OpenAI / Google Vision / Gemini ────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
