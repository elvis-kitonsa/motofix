# ─────────────────────────────────────────────────────────────────────────────
# motofix-diagnosis-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT validation ───────────────────────────────────────────────────────────
# Must match SECRET_KEY in motofix-auth-service so driver/mechanic tokens work.
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Port the service listens on (default: 8007).
PORT=8007

# ── Claude / Anthropic API ───────────────────────────────────────────────────
# Primary diagnosis engine: text diagnosis (/diagnose, /diagnose/guided),
# image verdicts (/diagnose/image) and the MOTOBOT chat (/chat).
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Groq API ─────────────────────────────────────────────────────────────────
# Used for Whisper voice-note transcription (/transcribe).
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
