# ─────────────────────────────────────────────────────────────────────────────
# motofix-insurance-service — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the insurance database.
DATABASE_URL=postgresql://postgres:password@localhost:5433/motofix_insurance

# ── JWT validation ───────────────────────────────────────────────────────────
# Must match SECRET_KEY in motofix-auth-service so driver tokens are accepted.
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Port the service listens on (default: 8006).
PORT=8006

# Directory where claim photos are saved (relative or absolute path).
UPLOADS_DIR=./uploads/claims
