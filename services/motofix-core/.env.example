# ─────────────────────────────────────────────────────────────────────────────
# motofix-core — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT validation ───────────────────────────────────────────────────────────
# Must match SECRET_KEY used by all other MOTOFIX services.
SECRET_KEY=change_me_in_production

ALGORITHM=HS256

# Port the gateway listens on (default: 8008).
PORT=8008

# Deployment environment: development | staging | production
ENV=development

# ── Downstream service URLs ───────────────────────────────────────────────────
# Override these in production to point at deployed service URLs.
AUTH_SERVICE_URL=http://localhost:8000
DISPATCH_SERVICE_URL=http://localhost:8001
VERIFICATION_SERVICE_URL=http://localhost:8002
MATCHING_SERVICE_URL=http://localhost:8003
NOTIFICATIONS_SERVICE_URL=http://localhost:8004
ANALYTICS_SERVICE_URL=http://localhost:8005
INSURANCE_SERVICE_URL=http://localhost:8006
DIAGNOSIS_SERVICE_URL=http://localhost:8007
