# ─────────────────────────────────────────────────────────────────────────────
# MOTOFIX .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets / environment ────────────────────────────────────────────────────
# NEVER commit these — they hold live API keys, private keys, DB credentials.
.env
.env.*
!.env.example
*.env
**/.env
**/.env.local
**/.env.*.local
*serviceAccount*.json
*service-account*.json
*firebase-adminsdk*.json
*.pem
*.key

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Node / frontend ──────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
dist/
dist-ssr/
build/
.vite/
.next/
.turbo/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Capacitor / mobile ───────────────────────────────────────────────────────
android/
ios/
.gradle/

# ── Databases / data ─────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres_data/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
